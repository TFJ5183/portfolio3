---
import ArrowEntry from "@/components/custom/arrowEntry.astro"
import Layout from "@/layouts/main.astro"
---

<Layout>
  <div class="absolute top-1/2 left-20 z-10 -translate-y-1/2">
    <h3 class="font-marker text-muted-foreground">Are you</h3>
    <h1 class="font-marker text-9xl tracking-widest text-primary">LOST?</h1>

    <div class="mt-8 max-w-2xl space-y-4 text-lg text-muted-foreground">
      <p>
        The page you are looking for doesn't exist or has been moved to another
        dimension. Let's get you back to safety.
      </p>
    </div>

    <ul class="mt-12 max-w-md space-y-2">
      <ArrowEntry link="/" className="h-full w-full"> Back to Home </ArrowEntry>
    </ul>
  </div>
</Layout>
