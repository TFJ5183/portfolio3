---
import ArrowEntry from "@/components/custom/arrowEntry.astro"
import Layout from "@/layouts/main.astro"
---

<Layout>
  <div class="absolute top-1/2 left-20 z-10 -translate-y-1/2">
    <h3 class="font-marker text-muted-foreground">Check out</h3>
    <h1 class="font-marker text-9xl tracking-widest text-primary">MY SKILLS</h1>

    <div class="mt-8 grid max-w-2xl grid-cols-2 gap-8">
      <div>
        <h2 class="mb-4 font-marker text-2xl text-primary">Frontend</h2>
        <ul class="space-y-1 text-muted-foreground">
          <li>Astro & React</li>
          <li>Tailwind</li>
          <li>TypeScript</li>
        </ul>
      </div>
      <div>
        <h2 class="mb-4 font-marker text-2xl text-primary">Backend</h2>
        <ul class="space-y-1 text-muted-foreground">
          <li>Java & Kotlin</li>
          <li>Spring</li>
          <li>GraphQL</li>
        </ul>
      </div>
      <div>
        <h2 class="mb-4 font-marker text-2xl text-primary">Tools</h2>
        <ul class="space-y-1 text-muted-foreground">
          <li>Git</li>
          <li>Docker</li>
          <li>Linux</li>
        </ul>
      </div>
      <div>
        <h2 class="mb-4 font-marker text-2xl text-primary">Misc</h2>
        <ul class="space-y-1 text-muted-foreground">
          <li>Minecraft Plugin</li>
          <li>Discord Bot</li>
        </ul>
      </div>
    </div>

    <ul class="mt-12 max-w-md space-y-2">
      <ArrowEntry>
        <a href="/about" class="block h-full w-full">Back to About</a>
      </ArrowEntry>
    </ul>
  </div>
</Layout>
