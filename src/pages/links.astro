---
import ArrowEntry from "@/components/custom/arrowEntry.astro"
import Layout from "@/layouts/main.astro"
import { links } from "./[...slug].astro"
import { CopyableUsername } from "@/components/custom/copyableUsername"
---

<Layout>
  <div class="absolute top-1/2 left-20 z-10 -translate-y-1/2">
    <h3 class="font-marker text-muted-foreground">You may know me from</h3>
    <h1 class="font-marker text-9xl tracking-widest text-primary">LINKS</h1>

    <ul class="max-w-md space-y-2">
      <ArrowEntry link="/"> Back to Home </ArrowEntry>

      {
        links
          .filter((link) => !link.hidden)
          .map((link) => (
            <ArrowEntry
              link={link.target}
              emptyWindow={true}
              className="flex items-center gap-4"
            >
              <link.icon class="h-6 w-6" />
              <span>{link.name}</span>
              {link.username && (
                <CopyableUsername
                  client:load
                  username={link.username}
                  isLinked={!!link.target}
                />
              )}
            </ArrowEntry>
          ))
      }
    </ul>
  </div>
</Layout>
