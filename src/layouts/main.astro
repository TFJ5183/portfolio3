---
import "@/styles/global.css"
import { Font } from "astro:assets"
---

<!-- Theme script -->
<script is:inline>
  const getThemePreference = () => {
    if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
      return localStorage.getItem("theme")
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light"
  }
  const isDark = getThemePreference() === "dark"
  document.documentElement.classList[isDark ? "add" : "remove"]("dark")

  if (typeof localStorage !== "undefined") {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains("dark")
      localStorage.setItem("theme", isDark ? "dark" : "light")
    })
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    })
  }
</script>

<!-- Template -->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>The Koi [dot] dev</title>
    <Font cssVariable="--marker-font" preload={true} />
  </head>
  <body>
    <div class="relative h-screen w-screen overflow-hidden">
      {/*  Background */}
      <div class="absolute inset-0 -z-10">
        <img
          alt="background"
          src="/background2.png"
          class="absolute inset-0 -z-10 h-full w-full object-cover blur-sm select-none"
        />
        <div
          class="absolute inset-0 bg-linear-to-r from-black to-black/25 md:to-transparent lg:via-black/25"
        >
        </div>
      </div>

      {/* Children */}
      <slot />

      {/* Loading bar */}
      <div
        id="loading-bar"
        class="absolute bottom-8 left-1/2 w-full max-w-[90%] -translate-x-1/2 px-0 transition-[max-width,padding] duration-1000 ease-in-out"
      >
        <div
          class="mb-2 flex justify-between font-mono text-xs tracking-widest text-muted-foreground uppercase opacity-50"
        >
          <span>System Status: Active</span>
          <span>Thekoi [dot] dev</span>
        </div>
        <div
          class="h-1 w-full overflow-hidden rounded-full bg-primary/10 transition-colors duration-1000"
        >
          <div
            class="h-full w-full rounded-full bg-muted opacity-30 shadow-[0_0_10px_rgba(var(--primary),0.5)] transition-colors duration-1000"
          >
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
