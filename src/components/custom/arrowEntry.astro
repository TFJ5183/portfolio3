---
// Props typ
type Props = {
  link?: string
  emptyWindow?: boolean
  className?: string
}

// Props
const { link, emptyWindow, className = "" } = Astro.props
---

<a href={link} target={emptyWindow ? "_blank" : "_self"}>
  <li
    class="group relative cursor-pointer rounded-lg px-4 py-3 transition-all duration-300"
  >
    {/* Arrow */}
    <div
      class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-start overflow-hidden rounded-2xl border-l border-primary opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    >
      <span class="font-marker text-8xl text-primary blur-sm">></span>
    </div>

    {/* Content */}
    <span class={"relative flex " + className}>
      <slot />
    </span>
  </li>
</a>
